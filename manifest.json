{
  "manifest_version": 3,
  "name": "RollerCoin Helper",
  "version": "2.0",
  "permissions": ["activeTab", "scripting", "tabs"],
  "host_permissions": ["*://*.rollercoin.com/*", "*://rollercoin.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "RollerCoin Helper"
  },
  "content_scripts": [
    {
      "matches": ["*://*.rollercoin.com/*", "*://rollercoin.com/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}
