{
  "manifest_version": 3,
  "name": "RollerCoin Auto Helper",
  "version": "2.2.8",
  "description": "RollerCoin otomatik oynatma ve coin toplama yardımcısı",
  "permissions": ["activeTab", "scripting", "tabs", "storage"],
  "host_permissions": ["*://*.rollercoin.com/*", "*://rollercoin.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "RollerCoin Auto Helper",
    "default_icon": "icon48.png"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["*://*.rollercoin.com/*", "*://rollercoin.com/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}
